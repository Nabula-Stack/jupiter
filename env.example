

# --- Database ---
DB_NAME=mydatabase
DB_USER=admin
DB_PASSWORD=mypassword
DB_HOST=db
DB_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,1,192.168.1.10,domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://domain.com
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_USE_X_FORWARDED_PORT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
SSH_PUBLIC_KEY_ENCRYPTION_KEY=

# --- SSH (ESXi connection) ---
# Preferred: key file path available inside the container
SSH_KEY_PATH=./vcenter_rsa
# Optional fallback: base64-encoded private key content
# Example (Linux/macOS): base64 --wrap=0 vcenter_rsa
# Example (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes(".\\vcenter_rsa"))
SSH_PRIVATE_KEY_B64=
# Path inside the container where entrypoint writes decoded key when SSH_PRIVATE_KEY_B64 is used
SSH_KEY_CONTAINER_PATH=/run/secrets/ssh_key

# --- Web port ---
WEB_PORT=8000
