# === CONTAINER: db (PostgreSQL) ===
DB_NAME=mydatabase
DB_USER=admin
DB_PASSWORD=mypassword
DB_HOST=db
DB_PORT=5432

# === CONTAINER: redis (Cache) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_TIMEOUT=300
REDIS_CACHE_MAX_CONNECTIONS=200

# === CONTAINER: web (Django) ===
DJANGO_SECRET_KEY=change-me-to-a-random-secret-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_USE_X_FORWARDED_PORT=True
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
SSH_PUBLIC_KEY_ENCRYPTION_KEY=change-me-to-a-random-encryption-key
WEB_PORT=8000
WEB_INTERNAL_PORT=8000
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=apass
DJANGO_SUPERUSER_EMAIL=admin

# === CONTAINER: sync-worker (Background Sync) ===
DJANGO_SECRET_KEY=change-me-to-a-random-secret-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SSH_PUBLIC_KEY_ENCRYPTION_KEY=change-me-to-a-random-encryption-key
SSH_KEY_PATH=/app/ssh_keys/rsa
ESXI_SSH_KEY_PATH=/app/ssh_keys/nebula_rsa
KVM_SSH_KEY_PATH=/app/ssh_keys/rsa

